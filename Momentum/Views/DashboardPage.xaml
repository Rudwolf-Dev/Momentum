<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Momentum.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Momentum.ViewModels"
    x:DataType="viewmodels:DashboardViewModel"
    xmlns:models="clr-namespace:Momentum.Models"
    Title="Dashboard"
    BackgroundColor="#121212">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="24">

            <!-- ===================================== -->
            <!-- HEADER -->
            <!-- ===================================== -->

            <VerticalStackLayout Spacing="4">

                <Label
                    Text="Welcome Back"
                    FontSize="14"
                    TextColor="#AAAAAA" />

                <Label
                    Text="Momentum"
                    FontSize="34"
                    FontAttributes="Bold"
                    TextColor="White" />

            </VerticalStackLayout>

            <!-- ===================================== -->
            <!-- PRODUCTIVITY CARD -->
            <!-- ===================================== -->

            <Border
                StrokeShape="RoundRectangle 28"
                BackgroundColor="#1E1E1E"
                Stroke="#2A2A2A"
                Padding="22">

                <VerticalStackLayout Spacing="16">

                    <Label
                        Text="Today's Progress"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <ProgressBar
                        Progress="{Binding ProductivityProgress}"
                        HeightRequest="10" />

                    <Label
                        Text="{Binding ProductivityText}"
                        FontSize="13"
                        TextColor="#AAAAAA" />

                </VerticalStackLayout>

            </Border>

            <!-- ===================================== -->
            <!-- QUICK STATS -->
            <!-- ===================================== -->

            <Grid
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="16"
                RowSpacing="16">

                <!-- TASKS -->

                <Border
                    Grid.Row="0"
                    Grid.Column="0"
                    StrokeShape="RoundRectangle 24"
                    BackgroundColor="#4F46E5"
                    Padding="20">

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="Tasks"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Label
                            Text="{Binding PendingTasks}"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Label
                            Text="Pending"
                            FontSize="12"
                            TextColor="#E5E5E5" />

                    </VerticalStackLayout>

                </Border>

                <!-- HABITS -->

                <Border
                    Grid.Row="0"
                    Grid.Column="1"
                    StrokeShape="RoundRectangle 24"
                    BackgroundColor="#059669"
                    Padding="20">

                    <VerticalStackLayout Spacing="10">

                        <Label
                            Text="Habits"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Label
                            Text="{Binding CompletedHabits}"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <Label
                            Text="Completed"
                            FontSize="12"
                            TextColor="#E5E5E5" />

                    </VerticalStackLayout>

                </Border>

                <!-- NOTES -->

                <Border
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    StrokeShape="RoundRectangle 24"
                    BackgroundColor="#1E1E1E"
                    Stroke="#2A2A2A"
                    Padding="20">

                    <VerticalStackLayout Spacing="12">

                        <Label
                            Text="Recent Notes"
                            FontSize="18"
                            FontAttributes="Bold"
                            TextColor="White" />

                        <CollectionView
    ItemsSource="{Binding RecentNotes}"
    SelectionMode="None">

                            <CollectionView.ItemTemplate>

                                <DataTemplate
            x:DataType="models:NoteItem">

                                    <Border
                Margin="0,0,0,10"
                StrokeShape="RoundRectangle 18"
                BackgroundColor="#2A2A2A"
                Padding="14">

                                        <VerticalStackLayout Spacing="4">

                                            <Label
                        Text="{Binding Title}"
                        FontSize="15"
                        FontAttributes="Bold"
                        TextColor="White" />

                                            <Label
                        Text="{Binding Content}"
                        FontSize="12"
                        MaxLines="2"
                        LineBreakMode="TailTruncation"
                        TextColor="#CCCCCC" />

                                        </VerticalStackLayout>

                                    </Border>

                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>

                </Border>

            </Grid>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>