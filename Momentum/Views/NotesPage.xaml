<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Momentum.Views.NotesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Momentum.ViewModels"
    x:DataType="viewmodels:NotesViewModel"
    xmlns:models="clr-namespace:Momentum.Models"
    Title="Notes"
    BackgroundColor="#121212">

    <VerticalStackLayout Padding="20" Spacing="20">

        <VerticalStackLayout>

            <Label
                    Text="Notas"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="White" />

            <Label
                    Text="Guarda tus ideas rápidamente"
                    FontSize="14"
                    TextColor="#AAAAAA" />

        </VerticalStackLayout>

        <Border
                Padding="15"
                BackgroundColor="#1E1E1E">

            <VerticalStackLayout Spacing="12">

                <Entry
                        Placeholder="Titulo..."
                        Text="{Binding NoteTitle}"
                        TextColor="White"
                        PlaceholderColor="#888888" />

                <Editor
                        Placeholder="Escribe algo..."
                        Text="{Binding NoteContent}"
                        TextColor="White"
                        PlaceholderColor="#888888"
                        HeightRequest="120"
                        BackgroundColor="Transparent" />

                <Button
                        Text="Guardar Nota"
                        Command="{Binding AddNoteCommand}"
                        HeightRequest="50"
                        CornerRadius="16"
                        BackgroundColor="#2563EB"
                        TextColor="White"
                        FontAttributes="Bold" />

            </VerticalStackLayout>

        </Border>

        <CollectionView
                ItemsSource="{Binding Notes}"
                SelectionMode="None">

            <CollectionView.ItemTemplate>

                <DataTemplate x:DataType="models:NoteItem">

                    <SwipeView>

                        <SwipeView.RightItems>

                            <SwipeItems>

                                <SwipeItem
                                        Text="Borrar"
                                        BackgroundColor="#DC2626"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:NotesViewModel}}, Path=DeleteNoteCommand}"
                                        CommandParameter="{Binding .}" />

                            </SwipeItems>

                        </SwipeView.RightItems>

                        <Border
                                Margin="0,0,0,12"
                                Padding="15"
                                BackgroundColor="#1E1E1E">

                            <VerticalStackLayout Spacing="6">

                                <Label
                                        Text="{Binding Title}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="White" />

                                <Label
                                        Text="{Binding Content}"
                                        FontSize="14"
                                        TextColor="#CCCCCC" />

                                <Label
                                        Text="{Binding CreatedAt, StringFormat='Created: {0:dd/MM/yyyy}'}"
                                        FontSize="11"
                                        TextColor="#888888" />

                            </VerticalStackLayout>

                        </Border>

                    </SwipeView>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>