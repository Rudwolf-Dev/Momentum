<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="Momentum.Views.HabitsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Momentum.ViewModels"
    x:DataType="viewmodels:HabitsViewModel"
    xmlns:models="clr-namespace:Momentum.Models"
    Title="Habits"
    BackgroundColor="#121212">

    <VerticalStackLayout Padding="20" Spacing="20">

        <VerticalStackLayout>

            <Label
                    Text="Hábitos"
                    FontSize="32"
                    FontAttributes="Bold"
                    TextColor="White" />

            <Label
                    Text="Crea consistencia para cada día..."
                    FontSize="14"
                    TextColor="#AAAAAA" />

        </VerticalStackLayout>

        <Border
                Padding="15"
                BackgroundColor="#1E1E1E"
                >

            <VerticalStackLayout Spacing="12">

                <Entry
                        Placeholder="Nuevo hábito..."
                        Text="{Binding HabitName}"
                        TextColor="White"
                        PlaceholderColor="#888888" />

                <Button
                        Text="Agregar hábito"
                        Command="{Binding AddHabitCommand}"
                        HeightRequest="50"
                        CornerRadius="16"
                        BackgroundColor="#059669"
                        TextColor="White"
                        FontAttributes="Bold" />

            </VerticalStackLayout>

        </Border>

        <CollectionView
                ItemsSource="{Binding Habits}"
                SelectionMode="None">

            <CollectionView.ItemTemplate>

                <DataTemplate x:DataType="models:HabitItem">

                    <SwipeView>

                        <SwipeView.RightItems>

                            <SwipeItems>

                                <SwipeItem
                                        Text="Borrar"
                                        BackgroundColor="#DC2626"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HabitsViewModel}}, Path=DeleteHabitCommand}"
                                        CommandParameter="{Binding .}" />

                            </SwipeItems>

                        </SwipeView.RightItems>

                        <Border
                                Margin="0,0,0,12"
                                Padding="15"
                                BackgroundColor="#1E1E1E">

                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout>

                                    <Label
                                            Text="{Binding Name}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="White" />

                                    <Label
                                            Text="{Binding Streak, StringFormat='🔥 Racha: {0}'}"
                                            FontSize="13"
                                            TextColor="#AAAAAA" />

                                </VerticalStackLayout>

                                <Button
                                        Grid.Column="1"
                                        Text="Done"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:HabitsViewModel}}, Path=CompleteHabitCommand}"
                                        CommandParameter="{Binding .}"
                                        HeightRequest="40"
                                        WidthRequest="80"
                                        CornerRadius="14"
                                        BackgroundColor="#059669"
                                        TextColor="White" />

                            </Grid>

                        </Border>

                    </SwipeView>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>